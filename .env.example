# Base Directory (automatic if left empty)
# BASE_DIR=C:\Projects\AI based

# Copernicus Sentinel-1 API Credentials
COPERNICUS_USERNAME=your_copernicus_username
COPERNICUS_PASSWORD=your_copernicus_password

# OpenWeatherMap or Auxiliary Weather API Key
WEATHER_API_KEY=your_weather_api_key

# Processing Settings
SPECKLE_FILTER_WINDOW=5
SPATIAL_RESOLUTION_METERS=10

# Model Settings
RANDOM_STATE=42
TEST_SIZE=0.2
BATCH_SIZE=32
LEARNING_RATE=0.0001
EPOCHS=50

# API Server Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Logging Configuration
LOG_LEVEL=INFO
